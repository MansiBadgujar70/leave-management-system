# Leave Management System - Environment Configuration Template
# Copy this file to '.env' and modify the values for your setup.
# DO NOT commit the '.env' file containing real secrets to GitHub!

# ─── Flask Settings ──────────────────────────────────────────────────────────
# Set to 'development' for local work, or 'production' for cloud deployment
FLASK_ENV=development
# Set to True to enable auto-reload and interactive debugger locally
FLASK_DEBUG=True

# ─── Security ────────────────────────────────────────────────────────────────
# A long, random secret key to sign session cookies. Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=leave-mgmt-super-secret-key-2024

# ─── Database ────────────────────────────────────────────────────────────────
# 1. Local Fallback (SQLite): If you leave DATABASE_URL blank or comment it out,
#    the application automatically uses a local SQLite database in the instance/ folder.
#    No installation or configuration needed!
#
# 2. Local/Remote MySQL (e.g. XAMPP):
# DATABASE_URL=mysql+pymysql://root:@localhost/leave_management_system
#
# 3. Cloud/Production PostgreSQL (e.g. Render/Supabase):
# DATABASE_URL=postgresql://user:password@host:port/database_name
# Note: Render automatically provides this variable in production.
